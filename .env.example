# ── Data APIs (all free-tier, only CRYPTOPANIC_TOKEN needs sign-up) ──────────
BINANCE_BASE=https://api.binance.com
COINGECKO_BASE=https://api.coingecko.com/api/v3
CRYPTOPANIC_TOKEN=          # https://cryptopanic.com/developers/api/
ALT_ME_BASE=https://api.alternative.me
DEFILLAMA_BASE=https://api.llama.fi
GECKOTERMINAL_BASE=https://api.geckoterminal.com/api/v2

# ── Bitget (only needed for live trading) ────────────────────────────────────
BITGET_BASE=https://api.bitget.com
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# ── Supabase (optional — for persisting backtests) ───────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Alerts (optional) ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_DIR=.cache
